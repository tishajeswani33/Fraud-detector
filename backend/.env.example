# ML Model directory
MODEL_DIR=./models

# CORS Origins (Comma-separated)
ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-app.vercel.app

# Uvicorn Settings
HOST=0.0.0.0
PORT=8000

# MySQL Database URL
# Format: mysql+pymysql://<user>:<password>@<host>/<database>
# For local development, ensure MySQL is running and the database 'fraud_detector' exists.
MYSQL_URL=mysql+pymysql://root:password@localhost/fraud_detector
